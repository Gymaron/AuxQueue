generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "sqlite"
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique 
  permissions Permission[]
  users       User[]
}

model Permission {
  id    String @id @default(uuid())
  name  String @unique
  roles Role[]
}

model User {
  id               String    @id @default(uuid())
  name             String    @unique
  email            String    @unique
  password         String
  
  twoFactorPin     String?
  twoFactorExpires DateTime?
  recoveryToken    String?
  recoveryExpires  DateTime?
  
  roleId           String?
  role             Role?     @relation(fields: [roleId], references: [id])
  
  songs            Song[]
}

model Party {
  id    String @id @default(uuid())
  name  String
  code  String @unique
  songs Song[]
}

model Song {
  id        String   @id @default(uuid())
  title     String
  artist    String
  album     String?
  genre     String?
  duration  String?
  votes     Int      @default(0)
  addedAt   DateTime @default(now())
  
  party     Party?   @relation(fields: [partyCode], references: [code], onDelete: Cascade)
  partyCode String?

  user      User?    @relation(fields: [addedBy], references: [name], onDelete: Cascade)
  addedBy   String?

  @@index([partyCode])
  @@index([addedBy])
  @@index([genre])
}

model Log {
  id        String   @id @default(uuid())
  userId    String
  groupId   String   
  action    String   
  timestamp DateTime @default(now())
}

model SuspiciousUser {
  id        String   @id @default(uuid())
  userName  String   @unique
  reason    String
  flaggedAt DateTime @default(now())
}