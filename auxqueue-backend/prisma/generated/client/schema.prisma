// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "sqlite"
}

// SILVER CHALLENGE: Roles and Permissions
model Role {
  id          String       @id @default(uuid())
  name        String       @unique // e.g., "ADMIN" or "USER"
  permissions Permission[]
  users       User[]
}

model Permission {
  id    String @id @default(uuid())
  name  String @unique
  roles Role[]
}

model User {
  id       String @id @default(uuid())
  name     String @unique
  email    String @unique
  password String

  // Link User to Role
  roleId String?
  role   Role?   @relation(fields: [roleId], references: [id])

  // 1-to-Many Relationship: A user can add many songs
  songs Song[]
}

model Party {
  id    String @id @default(uuid())
  name  String
  code  String @unique
  // 1-to-Many Relationship: A party can have many songs
  songs Song[]
}

model Song {
  id       String   @id @default(uuid())
  title    String
  artist   String
  album    String?
  genre    String?
  duration String?
  votes    Int      @default(0)
  addedAt  DateTime @default(now())

  // Foreign Key to Party
  party     Party?  @relation(fields: [partyCode], references: [code], onDelete: Cascade)
  partyCode String?

  // Foreign Key to User
  user    User?   @relation(fields: [addedBy], references: [name], onDelete: Cascade)
  addedBy String?
}

//Logging and Surveillance
model Log {
  id        String   @id @default(uuid())
  userId    String
  groupId   String // "ADMIN" or "USER"
  action    String // "ACTION_INFORMATION"
  timestamp DateTime @default(now())
}

model SuspiciousUser {
  id        String   @id @default(uuid())
  userName  String   @unique
  reason    String
  flaggedAt DateTime @default(now())
}
